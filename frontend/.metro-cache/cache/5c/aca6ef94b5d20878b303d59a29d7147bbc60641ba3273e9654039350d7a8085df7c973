:30'\n      }]\n    }];\n  }\n  async function getTickets() {\n    let list = await getStore(K.tickets, null);\n    if (!list) {\n      list = seedTickets();\n      await setStore(K.tickets, list);\n    }\n    return list;\n  }\n\n  // ---------- the mock API (mirrors src/api.ts `api`) ----------\n  const mockApi = {\n    // auth — single sign-in identity; role drives RBAC.\n    login: async (email, _password, _role) => {\n      await delay();\n      const user = currentMockUser(email ? {\n        email\n      } : {});\n      await setStore(K.user, user);\n      return {\n        token: `mock-token-${user.id}`,\n        user\n      };\n    },\n    otpRequest: async phone => {\n      await delay();\n      return {\n        ok: true,\n        phone,\n        demo_otp: '123456',\n        message: 'OTP sent (demo: 123456)'\n      };\n    },\n    otpVerify: async (phone, _code) => {\n      await delay();\n      const user = currentMockUser({\n        phone\n      });\n      await setStore(K.user, user);\n      return {\n        token: `mock-token-${user.id}`,\n        user\n      };\n    },\n    microsoft: async _email => {\n      await delay();\n      const user = currentMockUser();\n      await setStore(K.user, user);\n      return {\n        token: `mock-token-${user.id}`,\n        user\n      };\n    },\n    me: async () => {\n      await delay(60);\n      return getStore(K.user, currentMockUser());\n    },\n    demoAccounts: async () => {\n      await delay();\n      return [];\n    },\n    // exams\n    hallTicket: async () => {\n      await delay();\n      return clone(HALL_TICKET);\n    },\n    examAttendance: async () => {\n      await delay();\n      return [];\n    },\n    results: async () => {\n      await delay();\n      return clone(RESULTS);\n    },\n    // visitors\n    visitorRequest: async data => {\n      await delay();\n      const list = await getStore(K.visitors, []);\n      const rec = {\n        id: `v${Date.now()}`,\n        status: 'Pending',\n