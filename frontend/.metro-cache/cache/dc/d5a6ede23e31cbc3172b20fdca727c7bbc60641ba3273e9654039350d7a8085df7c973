y',\n        employee_id: 'MU-LIB204',\n        email: 'librarian@mahindrauniversity.edu.in',\n        status: 'active'\n      }, {\n        id: 'e3',\n        name: 'Mr. Ramesh Kale',\n        role: 'staff',\n        department: 'Security',\n        employee_id: 'MU-SEC011',\n        email: 'security@mahindrauniversity.edu.in',\n        status: 'active'\n      }];\n    },\n    adminAttendanceTrend: async () => {\n      await delay();\n      return [{\n        date: 'Mon',\n        present: 20\n      }, {\n        date: 'Tue',\n        present: 22\n      }, {\n        date: 'Wed',\n        present: 19\n      }, {\n        date: 'Thu',\n        present: 21\n      }, {\n        date: 'Fri',\n        present: 18\n      }];\n    },\n    adminAttendanceByDept: async () => {\n      await delay();\n      return [{\n        department: 'Computer Science',\n        present: 8,\n        total: 10\n      }, {\n        department: 'ECE',\n        present: 6,\n        total: 8\n      }, {\n        department: 'Library',\n        present: 2,\n        total: 3\n      }];\n    },\n    adminCreateGeofence: async data => {\n      await delay();\n      return Object.assign({\n        id: `gf${Date.now()}`\n      }, data);\n    },\n    adminUpdateGeofence: async (id, data) => {\n      await delay();\n      return Object.assign({\n        id\n      }, data);\n    },\n    adminDeleteGeofence: async id => {\n      await delay();\n      return {\n        ok: true,\n        id\n      };\n    },\n    adminMonthlyReport: async _month => {\n      await delay();\n      return {\n        month: 'June 2026',\n        rows: []\n      };\n    },\n    // mess\n    messList: async _demo => {\n      await delay();\n      return Object.assign({}, clone(MESS), {\n        current_meal: messCurrentMeal(),\n        server_time: nowIso()\n      });\n    },\n    // weather\n    weather: async () => {\n      await delay();\n      return clone(WEATHER);\n    },\n    // leave\n    leaveSummary: async () => {\n 