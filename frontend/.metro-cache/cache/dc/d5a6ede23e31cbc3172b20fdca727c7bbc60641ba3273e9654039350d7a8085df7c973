        check_out: null,\n          geofence_name: null\n        }]\n      };\n    },\n    // library\n    books: async _q => {\n      await delay();\n      return clone(BOOKS);\n    },\n    issueBook: async id => {\n      await delay();\n      const list = await getStore(K.issues, []);\n      if (!list.includes(id)) list.push(id);\n      await setStore(K.issues, list);\n      const bk = BOOKS.find(b => b.id === id);\n      return {\n        ok: true,\n        book: bk\n      };\n    },\n    myIssues: async () => {\n      await delay();\n      const ids = await getStore(K.issues, []);\n      return BOOKS.filter(b => ids.includes(b.id)).map(b => Object.assign({}, b, {\n        due_date: '2026-07-15',\n        issued_at: nowIso()\n      }));\n    },\n    // hostel\n    myRoom: async () => {\n      await delay();\n      return {\n        hostel: '—',\n        block: '—',\n        room: '—',\n        roommates: []\n      };\n    },\n    createComplaint: async d => {\n      await delay();\n      const list = await getStore(K.complaints, []);\n      const rec = Object.assign({\n        id: `c${Date.now()}`,\n        status: 'Open',\n        created_at: nowIso()\n      }, d);\n      list.unshift(rec);\n      await setStore(K.complaints, list);\n      return rec;\n    },\n    complaints: async () => {\n      await delay();\n      return getStore(K.complaints, []);\n    },\n    // events\n    events: async () => {\n      await delay();\n      return clone(EVENTS);\n    },\n    registerEvent: async event_id => {\n      await delay();\n      const list = await getStore(K.eventRegs, []);\n      if (!list.includes(event_id)) list.push(event_id);\n      await setStore(K.eventRegs, list);\n      return {\n        ok: true,\n        event_id\n      };\n    },\n    myRegistrations: async () => {\n      await delay();\n      const ids = await getStore(K.eventRegs, []);\n      return EVENTS.filter(e => ids.includes(e.id));\n    },\n    certificates: async () => {\n      await delay();